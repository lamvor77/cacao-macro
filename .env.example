# Supabase 클라우드 동기화 설정 (Phase 2, 선택 기능)
#
# 사용 방법: 이 파일을 같은 위치에 ".env"로 복사한 뒤 실제 값을 입력한다.
# .env 파일은 절대 git에 커밋하지 않는다 (.gitignore에 이미 등록되어 있음).
#
# SUPABASE_ENABLED=false 이거나 이 파일 자체가 없어도 프로그램은 정상
# 실행되며, 클라우드 동기화 없이 기존 로컬 JSON 저장/발송 기능만 동작한다.

# ===== 환경 구분 (Test Environment Deployment & E2E Validation Sprint) =====
# 아래 SUPABASE_URL/ANON_KEY가 운영이 아닌 테스트 전용 Supabase 프로젝트를
# 가리킬 때 반드시 함께 설정한다. 이 값이 있으면 창 제목표시줄과 진단 화면에
# "TEST ENVIRONMENT"가 명확히 표시된다(운영 배포본에는 이 값 자체를 넣지
# 않는다 — 값이 없으면 표시가 전혀 나타나지 않고 기존 동작과 동일하다).
APP_ENV=
SUPABASE_ENVIRONMENT=

# 클라우드 동기화 기능 사용 여부 (true/false)
SUPABASE_ENABLED=false

# Supabase 프로젝트 URL (예: https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Supabase anon(public) key.
# 반드시 anon key만 사용한다 — service_role key는 PC 프로그램에 절대 포함하지 않는다.
SUPABASE_ANON_KEY=

# (제거됨) SUPABASE_SYNC_INTERVAL_SECONDS — legacy messages의 상시 30초 전체
# 조회 polling을 제거하면서 더 이상 쓰이지 않는다. 지금은 로그인 직후 1회
# 조회 + 저장/발송 시작·종료/15분 조건부 시 push + 수동 새로고침 + 발송
# 직전 단건 확인으로 대체됐다(상시 polling 없음). 이 값이 .env에 남아있어도
# 프로그램은 정상 동작하며, 더 이상 사용되지 않는다는 경고 로그만 1회 남는다.

# 이 PC를 구분하기 위한 식별자 (메시지 updated_by 기록용).
# 비워두면 PC 호스트 이름 기반으로 자동 생성된다.
SUPABASE_DEVICE_ID=

# ===== Mobile 실시간 동기화 (shared_messages, 선택 기능) =====
#
# shared_messages 테이블 Realtime 구독을 켤지 여부. SUPABASE_ENABLED=false면
# 이 값과 무관하게 항상 꺼진다. SUPABASE_ENABLED=true인데 이 값만 false로
# 두면, 기존 messages 테이블 30초 폴링(레거시)은 그대로 동작하되 shared_messages
# 실시간 구독만 끌 수 있다(장애 시 임시 롤백 스위치 용도). 미설정 시 true.
SUPABASE_REALTIME_ENABLED=true

# 모바일 메시지 편집 웹의 배포 주소 — 코드에서 직접 사용하지는 않는다(정보 제공용).
# 운영자가 문의 응대나 사내 안내 문서에서 참고하는 용도로만 기록해 둔다.
MOBILE_APP_URL=

# shared_messages를 새 기준 데이터로 사용할지 여부(레거시 messages 테이블과의
# 이원 체계 전환 준비용 기능 플래그 — docs/legacy_messages_migration_plan.md
# 참고). 지금은 모두 기본값(true)이며 동작 변화가 없다. 원복(false)하면 즉시
# 레거시 경로로 되돌아간다.
SHARED_MESSAGES_ENABLED=true
LEGACY_MESSAGES_SYNC_ENABLED=true
SHARED_MESSAGES_PRIMARY=true

# Supabase Realtime protocol 2.0(배열 메시지) 호환 계층 사용 여부
# (services/realtime_protocol_compat.py). 기본 true. 문제가 생기면 코드
# 변경 없이 false로 즉시 끌 수 있다(원본 realtime 라이브러리 동작으로 복귀).
REALTIME_PROTOCOL_COMPAT=true

# 자동 발송 직전 개별 메시지 검증 정책. block=서버 확인이 안 되면 해당 메시지
# 발송을 보류(다음 발송 시각에 재시도), cached=마지막으로 알려진 캐시 내용으로
# 발송. 미설정 시 block(더 안전한 기본값).
MESSAGE_SEND_OFFLINE_POLICY=block
# 발송 직전 서버 조회 제한 시간(초).
MESSAGE_SEND_VERIFY_TIMEOUT_SECONDS=5
# 발송 직전 서버 조회 재시도 횟수.
MESSAGE_SEND_VERIFY_RETRY_COUNT=2

# 공유 메시지 동기화 관련 상세 로그를 남길지 여부(true/false). 미설정 시 false.
# true로 켜면 Realtime 상태 전이, message_no/revision 변경, 재연결 횟수,
# 발송 직전 검증 결과 등이 로그에 남는다(메시지 본문/토큰/키/세션 정보는
# 이 값과 무관하게 절대 남기지 않는다). 평소 운영에서는 false로 둔다.
MESSAGE_SYNC_DEBUG=false

# ===== Google 로그인 (Phase 2D, 선택 고급 설정) =====
#
# Google 로그인 버튼을 누르면 OS가 자동으로 골라주는 임시 localhost 포트에서
# 콜백을 받는다(기본값 — 대부분의 환경에서 이 값을 비워두면 된다). Supabase
# 대시보드의 Redirect URLs에 와일드카드 패턴(예: http://127.0.0.1:*/oauth/**)을
# 등록해두면 매번 포트가 달라져도 동작한다 — 자세한 설정 방법은
# docs/PHASE2D_GOOGLE_OAUTH.md 참고.
#
# 와일드카드 Redirect URL 등록이 여의치 않은 환경(또는 방화벽 정책상 특정
# 포트만 열어둔 경우)에는, 아래에 쉼표로 구분된 고정 포트 목록을 지정하면
# 그중 사용 가능한 첫 포트를 사용한다. 이 경우 Supabase 대시보드에는 이
# 포트들을 정확히 그대로(예: http://127.0.0.1:53682/oauth/**) 각각 등록해야
# 한다.
# 예: SUPABASE_OAUTH_CALLBACK_PORTS=53682,53683,53684
SUPABASE_OAUTH_CALLBACK_PORTS=

# ===== 메시지 로컬 자동 저장 + 클라우드 조건부 동기화 (Phase 2E) =====
#
# 입력창 로컬 자동 저장 사용 여부. 클라우드 설정과 무관하게 항상 동작한다
# (네트워크 상태와 무관하게 로컬 저장은 항상 성공해야 한다는 원칙).
MESSAGE_LOCAL_AUTOSAVE_ENABLED=true

# 마지막 입력 후 로컬 자동 저장까지 대기 시간(ms). 최소 300, 미설정 시 2000.
MESSAGE_LOCAL_AUTOSAVE_DELAY_MS=2000

# 변경사항(cloud_dirty)이 있을 때만 Supabase에 업로드를 시도하는 주기(초).
# 최소 60, 미설정 시 900(15분). 이 주기 사이에는 저장 버튼/발송 시작/종료
# 등 명시적 이벤트에서만 즉시 업로드한다.
MESSAGE_CLOUD_SYNC_INTERVAL_SECONDS=900

# 카카오 발송 시작 직전에 cloud_dirty이면 즉시(비동기) 업로드를 시도할지 여부.
MESSAGE_CLOUD_SYNC_ON_SEND_START=true

# 프로그램 종료 직전에 cloud_dirty이면 즉시 업로드를 시도할지 여부.
MESSAGE_CLOUD_SYNC_ON_EXIT=true

# 종료 시 업로드 완료를 기다리는 최대 시간(초). 0~5 범위, 미설정 시 2.
# 이 시간을 넘기면 업로드 완료를 기다리지 않고 종료를 계속 진행한다.
MESSAGE_CLOUD_SYNC_EXIT_WAIT_SECONDS=2

# ===== 라이선스 관리자 (Phase 3-2, 개발/빌드 담당자 전용) =====
#
# 아래 세 값은 최종 사용자에게 배포하는 .env에는 넣지 않는다 — 개발/빌드를
# 담당하는 사람의 로컬 환경에만 필요하다. 비어 있거나 "CHANGE_ME_"로 시작하는
# 값은 실제 설정으로 인정되지 않으며, 이 경우 관리자 인증/라이선스 발급 기능은
# 안전하게 차단된다(기본 비밀번호나 예제 키로 동작하지 않는다).

# 라이선스 발급 도구("관리자 모드") 진입 비밀번호.
# 개발/빌드 담당자 PC에서만 설정한다.
LICENSE_ADMIN_PASSWORD=

# 빌드용 라이선스 파일(license_build.json) 서명에 쓰이는 비밀키.
# 충분히 긴 임의의 문자열을 사용하고, 실제 값은 절대 커밋하지 않는다.
# 주의: 배포하는 exe가 실행 시점에 서명을 재검증하려면, 빌드된 exe와 같은
# 폴더에 이 값(LICENSE_SECRET_KEY)만 담은 별도 .env를 함께 배치해야 한다
# (LICENSE_ADMIN_PASSWORD/LICENSE_ADMIN_UI_ENABLED는 최종 사용자용 .env에
# 넣지 않는다 — 관리자 전용 값이므로).
LICENSE_SECRET_KEY=

# 라이선스 관리자 버튼을 화면에 표시할지 여부(true/false, 미설정 시 false).
# 일반 사용자 배포본은 항상 false로 둔다 — 개발/빌드 담당자 환경에서만 true로 설정.
LICENSE_ADMIN_UI_ENABLED=false
