# 모바일 웹(Vite)은 클라이언트에 그대로 노출되는 값만 담는다 — anon key 이외의
# 비밀값(SUPABASE_SERVICE_ROLE_KEY, LICENSE_SECRET_KEY, Google client secret,
# 운영 관리자 비밀번호 등)은 이 파일과 실제 .env 어디에도 절대 넣지 않는다
# (요구사항 19절). Vite는 VITE_ 접두사가 붙은 변수만 클라이언트 번들에 포함한다.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 테스트 배포임을 화면 상단 배너로 명확히 표시한다("test"일 때만 배너 렌더링,
# 운영 배포에는 이 값 자체를 넣지 않는다 — Test Environment Deployment &
# E2E Validation Sprint 1절).
VITE_APP_ENV=
